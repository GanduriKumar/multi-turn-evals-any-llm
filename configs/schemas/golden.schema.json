{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/golden.schema.json",
  "title": "Golden Expected Responses",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "expectations"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Semantic version of this golden file",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "conversation_id": { "type": "string", "minLength": 1 },
    "expectations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["turn_id", "expected"],
        "properties": {
          "conversation_id": { "type": "string", "minLength": 1 },
          "turn_id": { "type": "string", "minLength": 1 },
          "expected": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "text_variants": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "structured": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "decision": { "type": "string", "enum": ["ALLOW", "DENY"] },
                  "reason_code": { "type": "string", "minLength": 1 },
                  "next_action": { "type": "string", "minLength": 1 }
                }
              },
              "weights": {
                "type": "object",
                "properties": {
                  "correctness": { "type": "number", "minimum": 0 },
                  "consistency": { "type": "number", "minimum": 0 },
                  "adherence": { "type": "number", "minimum": 0 },
                  "hallucination": { "type": "number", "minimum": 0 }
                },
                "additionalProperties": false
              },
              "turn_weight": { "type": "number", "minimum": 0 },
              "constraints": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "rule": { "type": "string", "minLength": 1 },
                    "params": { "type": "object" },
                    "expr": { "type": "string", "minLength": 1 },
                    "message": { "type": "string" }
                  },
                  "anyOf": [
                    { "required": ["rule"] },
                    { "required": ["expr"] }
                  ],
                  "properties": {
                    "rule": { "type": "string", "minLength": 1 },
                    "params": { "type": "object" }
                  }
                }
              },
              "conditions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["type"],
                  "properties": {
                    "type": { "type": "string", "minLength": 1 },
                    "threshold": { "type": "number" },
                    "operator": { "type": "string", "enum": [">=", ">", "<=", "<", "==", "!="] }
                  }
                }
              }
            },
            "required": ["text_variants"]
          }
        }
      }
    },
    "final_outcome": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "conversation_id": { "type": "string", "minLength": 1 },
        "success": { "type": "boolean" },
        "must_include": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "must_not_include": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "metadata": { "type": "object" }
      }
    }
  }
  ,
  "allOf": [
    {
      "if": { "not": { "required": ["conversation_id"] } },
      "then": {
        "properties": {
          "expectations": {
            "items": {
              "required": ["conversation_id"]
            }
          },
          "final_outcome": {
            "required": ["conversation_id"]
          }
        }
      }
    }
  ]
}
