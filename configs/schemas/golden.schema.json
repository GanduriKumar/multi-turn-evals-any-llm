{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/golden.schema.json",
  "title": "Golden Expected Responses",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "conversation_id", "expectations"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Semantic version of this golden file",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "conversation_id": { "type": "string", "minLength": 1 },
    "expectations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["turn_id", "expected"],
        "properties": {
          "turn_id": { "type": "string", "minLength": 1 },
          "expected": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "text_variants": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "structured": { "type": "object" },
              "weights": {
                "type": "object",
                "properties": {
                  "correctness": { "type": "number", "minimum": 0 },
                  "consistency": { "type": "number", "minimum": 0 },
                  "adherence": { "type": "number", "minimum": 0 },
                  "hallucination": { "type": "number", "minimum": 0 }
                },
                "additionalProperties": false
              },
              "constraints": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["rule"],
                  "properties": {
                    "rule": { "type": "string", "minLength": 1 },
                    "params": { "type": "object" }
                  }
                }
              },
              "conditions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["type"],
                  "properties": {
                    "type": { "type": "string", "minLength": 1 },
                    "threshold": { "type": "number" },
                    "operator": { "type": "string", "enum": [">=", ">", "<=", "<", "==", "!="] }
                  }
                }
              }
            },
            "required": ["text_variants"]
          }
        }
      }
    }
  }
}
