{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/run_config.schema.json",
  "title": "Evaluation Run Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "datasets", "models"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Semantic version of this run config",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "run_id": { "type": "string", "minLength": 1 },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "output_dir": { "type": "string" },
    "random_seed": { "type": "integer" },
    "datasets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["conversation", "golden"],
        "properties": {
          "id": { "type": "string" },
          "conversation": { "type": "string", "minLength": 1 },
          "golden": { "type": "string", "minLength": 1 },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "difficulty": { "type": "string" }
        }
      }
    },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "provider", "model"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "provider": { "type": "string", "minLength": 1 },
          "model": { "type": "string", "minLength": 1 },
          "params": { "type": "object", "additionalProperties": true },
          "concurrency": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "max_requests_per_second": { "type": "number", "minimum": 0 },
              "max_concurrent_requests": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    },
    "metric_bundles": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "basic_text",
          "structured",
          "constraints",
          "final_outcome"
        ]
      }
    },
    "truncation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "strategy": { "type": "string", "enum": ["none", "head", "tail", "middle"] },
        "max_input_tokens": { "type": "integer", "minimum": 1 }
      }
    },
    "concurrency": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_workers": { "type": "integer", "minimum": 1 },
        "per_model": { "type": "integer", "minimum": 1 }
      }
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "turn_pass": { "type": "number", "minimum": 0, "maximum": 1 },
        "conversation_pass": { "type": "number", "minimum": 0, "maximum": 1 },
        "metric": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  }
}
