{
  "version": "1.0.0",
  "datasets": [
    {
      "conversation": "configs/datasets/examples/conversation_001.json",
      "golden": "configs/datasets/examples/conversation_001.golden.yaml",
      "id": "conv001",
      "tags": [
        "commerce",
        "refund"
      ],
      "difficulty": "easy"
    }
  ],
  "models": [
    {
      "name": "dummy-1",
      "provider": "dummy",
      "model": "dummy-v1",
      "params": {
        "temperature": 0.0
      },
      "concurrency": {
        "max_requests_per_second": 5,
        "max_concurrent_requests": 2
      }
    },
    {
      "name": "dummy-2",
      "provider": "dummy",
      "model": "dummy-v2",
      "params": null,
      "concurrency": null
    }
  ],
  "run_id": "sample-20260103",
  "name": "Sample Run with Multiple Datasets and Models",
  "description": "Demonstrates selecting datasets, models, metrics, truncation and concurrency",
  "output_dir": "runs/sample_output",
  "random_seed": 42,
  "metric_bundles": [
    "basic_text",
    "structured",
    "constraints",
    "final_outcome"
  ],
  "truncation": {
    "strategy": "none",
    "max_input_tokens": 4096
  },
  "concurrency": {
    "max_workers": 4,
    "per_model": 2
  },
  "thresholds": {
    "turn_pass": 0.7,
    "conversation_pass": 0.75,
    "metric": {
      "correctness": 0.8,
      "adherence": 0.7,
      "consistency": 0.6,
      "hallucination": 0.9
    }
  }
}